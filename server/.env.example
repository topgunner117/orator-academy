# Copy to .env and fill in what you have. EVERY integration has a dev-mock/dormant fallback,
# so the server boots and the whole UI works with NONE of these set — fill them in as you go.

# ── Anthropic (photo notes + Zelle/email parsing) ──────────────────────────────
ANTHROPIC_API_KEY=
# Vision model for photo notes. Default claude-sonnet-4-6. claude-opus-4-8 = hardest handwriting.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Cheap model that parses ALL payment emails (PayPal, Venmo, Zelle). A regex fallback handles
# PayPal/Venmo offline when ANTHROPIC_API_KEY is unset.
ANTHROPIC_EMAIL_MODEL=claude-haiku-4-5-20251001

# ── Database ───────────────────────────────────────────────────────────────────
# LEAVE BLANK for local dev → state is saved to a local JSON file (server/data/db.json),
# no database to install. In the cloud, set this to your Neon/Railway Postgres URL.
# Use a SEPARATE DATABASE_URL for the test instance vs the production instance.
DATABASE_URL=

# ── Twilio (the "Text payment reminder" button) ────────────────────────────────
# Unset → texts are dev-mocked (logged, not sent). Set all three to send real SMS.
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Parser inbox (Gmail payment auto-apply) ────────────────────────────────────
# A brand-new dedicated Gmail YOU own (NOT the teacher's). Turn on 2-Step Verification and
# create an App Password — that 16-char app password goes in PARSER_IMAP_PASS. Unset → the
# poller stays dormant; use the in-app dev "Simulate email" tool to test the pipeline.
PARSER_IMAP_USER=
PARSER_IMAP_PASS=
PARSER_IMAP_HOST=imap.gmail.com
PARSER_IMAP_PORT=993
PARSER_POLL_SECONDS=60

# ── Misc ───────────────────────────────────────────────────────────────────────
PORT=8787
STUDIO_TIMEZONE=America/New_York
